{
  "name": "dollarmind-backend",
  "version": "0.1.0",
  "private": true,
  "description": "DollarMind — smart finance management (backend).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx ../scripts/migrate.ts",
    "seed": "tsx ../scripts/seed.ts"
  },
  "dependencies": {
    "@dollarmind/core": "*",
    "bcryptjs": "^2.4.3",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.4",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
