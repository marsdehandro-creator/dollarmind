# DollarMind backend environment. Copy to .env and adjust.
# App-specific variables use the DOLLARMIND_ prefix (legacy unprefixed names
# are still accepted as a fallback).

DOLLARMIND_ENV=development
DOLLARMIND_PORT=4000

# Local SQLite database file (pilot). See db/schema.sql.
DOLLARMIND_DATABASE_PATH=../db/dollarmind.db

# Path to the runtime config directory (JSON config files).
DOLLARMIND_CONFIG_DIR=../config

# JWT signing secret (replace with a secure value).
DOLLARMIND_JWT_SECRET=change-me-in-a-real-environment

# Access token lifetime, in seconds.
DOLLARMIND_JWT_EXPIRES_IN=3600
