{
  "$schema": "./security-policies.schema.json",
  "description": "Security policy configuration (see docs/security.md). Values here are enforced by the backend in Phase 6.",
  "password": {
    "algorithm": "argon2id",
    "minLength": 12,
    "screenBreachedPasswords": true,
    "forceRotation": false
  },
  "session": {
    "type": "server-side",
    "idleTimeoutMinutes": 30,
    "absoluteTimeoutHours": 24,
    "cookie": {
      "httpOnly": true,
      "secure": true,
      "sameSite": "lax"
    }
  },
  "lockout": {
    "maxFailedAttempts": 5,
    "lockoutMinutes": 15,
    "backoff": "exponential"
  },
  "mfa": {
    "enabledInPilot": false,
    "requiredForRoles": ["admin", "support"],
    "supportedFactors": ["totp", "webauthn", "recovery_code"]
  },
  "upload": {
    "validateContentType": true,
    "maxFileSizeBytes": 10485760,
    "sandboxParsing": true,
    "neutralizeCsvFormulaInjection": true
  },
  "audit": {
    "appendOnly": true,
    "loggedActions": [
      "auth.login.success",
      "auth.login.failure",
      "auth.logout",
      "auth.password.reset",
      "mfa.enrolled",
      "data.export",
      "data.erase",
      "role.change",
      "consent.change"
    ]
  }
}
