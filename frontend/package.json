{
  "name": "dollarmind-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DollarMind — smart finance management (frontend).",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run build && cap sync android && cap open android",
    "assets:generate": "capacitor-assets generate --assetPath dollarmind-assets --iconBackgroundColor '#0A0F2C' --splashBackgroundColor '#0A0F2C'"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.24.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "//capacitor": "Runtime deps for native builds — install with: npm i @capacitor/core @capacitor/android",
  "optionalDependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/core": "^6.2.1"
  }
}
