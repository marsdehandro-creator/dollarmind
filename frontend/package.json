{
  "name": "dollarmind-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DollarMind — smart finance management (frontend).",
  "scripts": {
    "predev": "node scripts/copy-assets.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-assets.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run build && cap sync android && cap open android",
    "assets:generate": "capacitor-assets generate --android"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.0",
    "@capacitor/android": "^6.1.0",
    "@capacitor/core": "^6.2.1",
    "@dollarmind/core": "*",
    "@tesseract.js-data/eng": "1.0.0",
    "pdfjs-dist": "^4.6.0",
    "sql.js": "^1.11.0",
    "tesseract.js": "^5.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.24.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.1",
    "@types/sql.js": "^1.4.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
